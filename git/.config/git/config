# useful git aliases
[alias]
	s = status
	graph = log --graph --oneline --decorate
	pullall = "!f(){ git pull \"$@\" && git submodule update --init --recursive; }; f"

# turn the colours on
[color]
	ui = auto
	branch = auto
	diff = auto
	grep = auto

# push behaviour
[push]
	default = simple

[include]
	path = ~/.config/git/colours.conf
