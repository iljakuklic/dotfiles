# useful git aliases
[alias]
	s = status
	ci = commit -p
	dc = diff --cached
	redmine = grep -pni -e redmine
	graph = log --graph --oneline --decorate
	pullall = "!f(){ git pull \"$@\" && git submodule update --init --recursive; }; f"
	checkoutall = !sh -c 'git checkout $1 && git submodule update --recursive' -
	cloneall = clone --recursive
	whatsnew = !sh -c 'git log $1@{1}..$1@{0} "$@"'

# turn the colours on
[color]
	ui = auto
	branch = auto
	diff = auto
	grep = auto

# push behaviour
[push]
	default = simple

# colours
[include]
	path = ~/.config/git/colours.conf
