    "glob": "allow",
    "list": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "codesearch": "allow",
    "websearch": "allow",
    "question": "allow"
  },
  "provider": {
    "NanoGPT": {
      "models": {
        "anthropic/claude-sonnet-4.6": {},
        "claude-haiku-4-5-20251001": {}
      }
    }
