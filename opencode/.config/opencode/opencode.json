{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "bash": {
        "*": "ask",
        "git diff": "allow",
        "git diff *": "allow",
        "git status": "allow",
        "git log": "allow",
        "git log *": "allow",
        "cargo check": "allow",
        "cargo check *": "allow",
        "cargo test": "allow",
        "cargo test *": "allow"
    },
    "read": "allow",
