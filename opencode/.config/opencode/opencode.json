{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "bash": {
        "*": "ask",
        "git diff": "allow",
        "git diff *": "allow",
        "git status": "allow",
        "git log": "allow",
        "git log *": "allow",
        "cargo check": "allow",
        "cargo check *": "allow",
        "cargo test": "allow",
        "cargo test *": "allow"
    },
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "codesearch": "allow",
    "websearch": "allow",
    "question": "allow"
  },
  "provider": {
    "NanoGPT": {
      "name": "NanoGPT Custom",
      "options": {
        "baseURL": "https://nano-gpt.com/api/v1"
      },
      "models": {
        "anthropic/claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "cost": { "input": 2.992, "output": 14.99 },
          "limit": { "context": 1000000, "output": 1000000 }
        },
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5",
          "cost": { "input": 1, "output": 5 },
          "limit": { "context": 200000, "output": 200000 }
        }
      }
    }
  }
}
